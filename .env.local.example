# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/dealsync"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-32-char-string"

# Anthropic Claude API
# 비워두면 데모 모드로 동작합니다(샘플 보고서 자동 생성).
# 실제 키(sk-ant-...)를 입력하면 자동으로 실제 AI 생성으로 전환됩니다.
ANTHROPIC_API_KEY="sk-ant-..."
# 선택: 사용할 모델명 (미지정 시 기본값 사용)
ANTHROPIC_MODEL=""

# AWS S3 (optional - uses local /uploads for dev)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""

# Storage mode: "local" | "s3"
STORAGE_MODE="local"

# Upload directory (for local mode)
UPLOAD_DIR="./public/uploads"

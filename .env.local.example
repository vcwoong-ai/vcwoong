# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/dealsync"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-32-char-string"

# Anthropic Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# AWS S3 (optional - uses local /uploads for dev)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""

# Storage mode: "local" | "s3"
STORAGE_MODE="local"

# Upload directory (for local mode)
UPLOAD_DIR="./public/uploads"

// Local development schema (SQLite) — production uses schema.prisma (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────
// Auth models (NextAuth.js)
// ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ───────────────────────────────────────────────
// Core models
// ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(ANALYST)
  teamId        String?
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  billingKey         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  team      Team?      @relation(fields: [teamId], references: [id])
  deals     Deal[]
  templates Template[]
  usageLogs UsageLog[]
  payments  SubscriptionPayment[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  deals     Deal[]
  templates Template[]
}

model Deal {
  id           String     @id @default(cuid())
  name         String
  companyName  String
  sector       DealSector
  stage        DealStage  @default(SCREENING)
  status       DealStatus @default(ACTIVE)
  description  String?
  investAmount Float?
  investRound  String?
  valuation    Float?
  userId       String
  teamId       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  team      Team?      @relation(fields: [teamId], references: [id])
  documents Document[]
  reports   Report[]
}

model Document {
  id         String       @id @default(cuid())
  dealId     String
  name       String
  type       DocumentType
  url        String
  size       Int
  mimeType   String
  parsedText String?
  metadata   Json?
  createdAt  DateTime     @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

model Template {
  id           String         @id @default(cuid())
  name         String
  description  String?
  fileType     TemplateFileType
  originalName String
  fileUrl      String
  fileSize     Int
  structure    Json?          // 추출된 섹션 구조
  sectionMap   Json?          // AI 매핑 결과 (templateSection → SectionKey)
  status       TemplateStatus @default(PENDING)
  userId       String
  teamId       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  team    Team?    @relation(fields: [teamId], references: [id])
  reports Report[]
}

model Report {
  id          String       @id @default(cuid())
  dealId      String
  templateId  String?
  title       String
  agentType   AgentType
  status      ReportStatus @default(PENDING)
  exportUrl   String?
  generatedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  deal     Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  template Template?       @relation(fields: [templateId], references: [id])
  sections ReportSection[]
}

model ReportSection {
  id        String        @id @default(cuid())
  reportId  String
  sectionKey SectionKey
  title     String
  content   String
  order     Int
  status    SectionStatus @default(DRAFT)
  feedback  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

// ───────────────────────────────────────────────
// Enumerations
// ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  PARTNER
  ANALYST
}

enum SubscriptionPlan {
  FREE
  SOLO
  SECTOR_PRO
  MULTI
  FULL
  BIO_PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model SubscriptionPayment {
  id         String           @id @default(cuid())
  userId     String
  plan       SubscriptionPlan
  amount     Int
  status     String
  paymentKey String?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DealSector {
  BIO
  IT
  GENERAL
  FINTECH
  CONSUMER
  DEEPTECH
  CLIMATE
  MANUFACTURING
  CONTENT
}

enum DealStage {
  SCREENING
  DEEP_DIVE
  IC_PREP
  IC_REVIEW
  CLOSED
  REJECTED
}

enum DealStatus {
  ACTIVE
  ARCHIVED
  ON_HOLD
}

enum DocumentType {
  IR_DECK
  FINANCIAL
  PATENT
  CONTRACT
  RESEARCH
  OTHER
}

enum AgentType {
  GENERAL
  BIO
  IT
  DEEPTECH
  MANUFACTURING
  CONTENT
  FINTECH
}

enum ReportStatus {
  PENDING
  GENERATING
  DRAFT
  REVIEW
  FINAL
  EXPORTED
}

enum SectionStatus {
  DRAFT
  REVIEWED
  APPROVED
}

model UsageLog {
  id           String    @id @default(cuid())
  userId       String
  dealId       String?
  reportId     String?
  agentType    AgentType
  sectionKey   SectionKey?
  model        String
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
  totalTokens  Int       @default(0)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum TemplateFileType {
  DOCX
  PPTX
}

enum TemplateStatus {
  PENDING
  ANALYZING
  READY
  ERROR
}

enum SectionKey {
  INVESTMENT_OVERVIEW
  COMPANY_OVERVIEW
  PRODUCT_TECHNOLOGY
  MARKET_ANALYSIS
  FINANCIAL_STATUS
  VALUATION
  RISK_ANALYSIS
  INVESTMENT_TERMS
  OPINION_SUMMARY
  APPENDIX
}
